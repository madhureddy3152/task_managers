#!/usr/bin/env sh
# ----------------------------------------------------------------------------
# Maven wrapper script
# ----------------------------------------------------------------------------

set -e

MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$0")" && pwd -P)"

if [ -z "$MAVEN_HOME" ]; then
  MAVEN_HOME="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
fi

MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  echo "Maven wrapper JAR not found. Please run the wrapper download command or place the jar at $MAVEN_WRAPPER_JAR"
  exit 1
fi

exec java -cp "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
